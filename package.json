{
  "name": "@b10cks/sdk",
  "version": "2.0.0",
  "description": "Official b10cks SDKs",
  "license": "MIT",
  "author": {
    "name": "Michael Wallner",
    "email": "m.wallner@coderscantina.com",
    "url": "https://github.com/b10cks"
  },
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "module": "index.ts",
  "scripts": {
    "build": "pnpm run build:packages",
    "build:packages": "pnpm --filter='@b10cks/client' run build && pnpm --filter='@b10cks/mgmt-client' run build && pnpm --filter='@b10cks/vue' run build && pnpm --filter='@b10cks/react' run build && pnpm --filter='@b10cks/svelte' run build && pnpm --filter='@b10cks/nuxt' run build && pnpm --filter='@b10cks/next' run build",
    "test": "pnpm --filter='*' run test",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "format": "oxfmt --write .",
    "clean": "pnpm --filter='*' run clean",
    "version:check": "pnpm run scripts/version-check.js",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "release": "pnpm run build && pnpm run changeset:publish"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^6.0.4"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "ajv": "^8.17.1",
    "oxfmt": "^0.28.0",
    "oxlint": "^1.43.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-dts": "^4.5.4"
  },
  "engines": {
    "node": ">=24.7.0"
  },
  "packageManager": "pnpm@10.15.1"
}
