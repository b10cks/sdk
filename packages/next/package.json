{
  "name": "@b10cks/next",
  "version": "0.2.0",
  "description": "Next.js integration SDK for b10cks",
  "license": "MIT",
  "author": "Michael Wallner @ Coder's Cantina",
  "repository": {
    "type": "git",
    "url": "https://github.com/b10cks/sdk.git",
    "directory": "packages/next"
  },
  "source": "src/index.ts",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs",
      "require": "./dist/server.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest",
    "lint": "biome lint --write .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@b10cks/client": "workspace:^",
    "@b10cks/react": "workspace:^",
    "@b10cks/richtext": "workspace:^"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "next": "^14.2.0 || ^15.0.0 || ^16.0.0",
    "react": "^18.3.0 || ^19.0.0",
    "react-dom": "^18.3.0 || ^19.0.0"
  },
  "release": {
    "branches": [
      "main"
    ]
  }
}
