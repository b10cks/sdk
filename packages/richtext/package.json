{
  "name": "@b10cks/richtext",
  "version": "0.1.0",
  "description": "Framework-agnostic rich text rendering for b10cks Rich text",
  "license": "MIT",
  "author": "Michael Wallner @ Coder's Cantina",
  "repository": {
    "type": "git",
    "url": "https://github.com/b10cks/sdk.git",
    "directory": "packages/richtext"
  },
  "source": "src/index.ts",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest",
    "lint": "biome lint --write .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@tiptap/core": "^2.26.1",
    "@tiptap/extension-link": "^2.26.1",
    "@tiptap/extension-table": "^2.26.1",
    "@tiptap/extension-table-cell": "^2.26.1",
    "@tiptap/extension-table-header": "^2.26.1",
    "@tiptap/extension-table-row": "^2.26.1",
    "@tiptap/extension-underline": "^2.26.1",
    "@tiptap/html": "^2.26.1",
    "@tiptap/starter-kit": "^2.26.1"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {},
  "release": {
    "branches": [
      "main"
    ]
  }
}
