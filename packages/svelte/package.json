{
  "name": "@b10cks/svelte",
  "version": "0.2.0",
  "description": "Svelte SDK for integrating b10cks into Svelte applications",
  "license": "MIT",
  "author": "Michael Wallner @ Coder's Cantina",
  "repository": {
    "type": "git",
    "url": "https://github.com/b10cks/sdk.git",
    "directory": "packages/svelte"
  },
  "source": "src/index.ts",
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "svelte": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "test": "vitest",
    "lint": "biome lint --write .",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@b10cks/client": "workspace:^",
    "@b10cks/richtext": "workspace:^"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^6.2.1",
    "svelte": "^5.40.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.4",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^3.2.4"
  },
  "peerDependencies": {
    "svelte": "^5.0.0 || ^4.2.0"
  },
  "release": {
    "branches": [
      "main"
    ]
  }
}
